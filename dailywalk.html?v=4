function renderWater() {
const count=S.dayData.water||0;
return `<div style="padding:.6rem .5rem;background:rgba(255,255,255,.45);border-radius:8px;border:1px solid #EDE0CD;margin-top:.3rem"> <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.4rem"> <div style="display:flex;align-items:center;gap:.5rem"><span>💧</span><span style="font-size:.85rem;font-weight:500;color:#1C1008">Water Intake</span></div> <span style="font-family:'Cormorant Garamond',serif;font-size:.9rem;color:#1A4A6B;font-weight:600">${count}/8 glasses</span> </div> <div style="display:flex;gap:5px"> ${Array.from({length:8},(_,i)=>`<div onclick="setWater(${i<count?i:i+1})" style="flex:1;aspect-ratio:1;border-radius:50%;background:${i<count?'#1A4A6B':'rgba(26,74,107,.12)'};border:2px solid ${i<count?'#1A6A9A':'#C4D9E8'};cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;font-size:.6rem">${i<count?’<span style="color:white">●</span>’:’’}</div>`).join(’’)}
</div>

  </div>`;
}

function renderJournal() {
const card=(t,s,body)=>`<section style="margin:0 1.5rem 1.1rem;padding:1.2rem;background:rgba(255,255,255,.65);border-radius:14px;border:1px solid #EDE0CD"><h2 style="font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:600;color:#1C1008;margin-bottom:.2rem">${t}</h2><p style="font-size:.67rem;letter-spacing:.06em;color:#A08060;margin-bottom:.9rem;font-style:italic">${s}</p>${body}</section>`;
return `<div class="fade"> ${card('Three Thanksgivings','Enter His gates with thanksgiving — Psalm 100:4', [0,1,2].map(i=>`<div style="display:flex;align-items:center;gap:.75rem;margin-bottom:.6rem">
<span style="font-family:'Cormorant Garamond',serif;font-size:1.1rem;color:#C4871F;font-weight:600;width:1.2rem;flex-shrink:0">${i+1}</span>
<input data-journal="grat-${i}" value="${esc(S.dayData.gratitude[i]||'')}" placeholder="${['I am grateful for...','Today I thank God for...','A blessing I see...'][i]}" style="flex:1;padding:.5rem .75rem;border:1px solid #EDE0CD;border-radius:6px;font-size:.85rem;background:rgba(255,255,255,.8);color:#1C1008">
</div>`).join('') )} ${card('Scripture Meditation',"Write today's scripture in your own words — what is the Spirit highlighting?", `<textarea data-journal="meditation" rows="5" placeholder="${S.content?`Reflect on ${S.content.ref}... What phrase stood out?`:'What is the Holy Spirit saying through today\'s verse?'}" style="width:100%;padding:.8rem;border:1px solid #EDE0CD;border-radius:8px;font-size:1.05rem;line-height:1.7;font-family:'Cormorant Garamond',serif;font-style:italic;background:rgba(255,255,255,.8);color:#1C1008;resize:none">${esc(S.dayData.meditation||’’)}</textarea>`)} ${card('Revelations & Notes','What is God speaking to you today?',`<textarea data-journal="notes" rows="7" placeholder="Write anything the Lord is speaking... a word, a picture, an impression, a conviction..." style="width:100%;padding:.8rem;border:1px solid #EDE0CD;border-radius:8px;font-size:.88rem;line-height:1.8;background:rgba(255,255,255,.8);color:#1C1008;resize:none">${esc(S.dayData.notes||’’)}</textarea>`)} ${card('Memory Verse','One verse to carry with you this week — saved across days',`<textarea data-journal="memverse" rows="3" placeholder="Write a verse you are hiding in your heart this week..." style="width:100%;padding:.8rem;border:1px solid #EDE0CD;border-radius:8px;font-size:1rem;line-height:1.65;font-family:'Cormorant Garamond',serif;font-style:italic;background:rgba(255,255,255,.8);color:#1C1008;resize:none">${esc(S.memVerse||’’)}</textarea>`
)}

  </div>`;
}

function renderPrayer() {
return `<div class="fade"><section style="margin:0 1.5rem 1.1rem;padding:1.2rem;background:rgba(255,255,255,.65);border-radius:14px;border:1px solid #EDE0CD"> <h2 style="font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:600;color:#1C1008;margin-bottom:.2rem">Prayer Intentions</h2> <p style="font-size:.67rem;letter-spacing:.06em;color:#A08060;margin-bottom:.9rem;font-style:italic">Bring them before the throne of grace — Hebrews 4:16</p> ${S.dayData.prayers.length?S.dayData.prayers.map((p,i)=>`<div style="display:flex;align-items:center;gap:.6rem;padding:.6rem .75rem;margin-bottom:.35rem;border-radius:8px;background:${p.done?'rgba(92,122,81,.07)':'rgba(255,255,255,.65)'};border:1px solid #EDE0CD">
<div onclick="togglePrayer(${i})" style="width:20px;height:20px;border-radius:50%;border:2px solid ${p.done?'#5C7A51':'#C4A882'};background:${p.done?'#5C7A51':'transparent'};display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0">
${p.done?’<span style="color:white;font-size:.72rem;font-weight:700">✓</span>’:’’}
</div>
<span style="flex:1;font-size:.85rem;color:#1C1008;text-decoration:${p.done?'line-through':'none'};opacity:${p.done?0.5:1}">${esc(p.text)}</span>
<button onclick="deletePrayer(${i})" style="background:none;border:none;color:#C4A882;font-size:1.1rem;cursor:pointer;line-height:1;padding:0 .1rem">×</button>
</div>`).join(''):`<div style="padding:1.2rem;text-align:center;color:#C4A882;font-family:'Cormorant Garamond',serif;font-style:italic;font-size:.95rem;margin-bottom:.5rem">Your intercessions will appear here 🙏</div>`} <div style="display:flex;gap:.5rem;margin-bottom:1rem"> <input id="prayer-input" value="${esc(S.newPrayer)}" placeholder="Add a prayer intention... (press Enter)" onkeydown="if(event.key==='Enter')addPrayer()" oninput="S.newPrayer=this.value" style="flex:1;padding:.55rem .75rem;border:1px solid #EDE0CD;border-radius:8px;font-size:.85rem;background:rgba(255,255,255,.8);color:#1C1008"> <button onclick="addPrayer()" style="background:linear-gradient(135deg,#C4871F,#E8A840);color:white;border:none;border-radius:8px;width:38px;font-size:1.4rem;cursor:pointer;font-weight:300;line-height:1;box-shadow:0 2px 10px rgba(196,135,31,.3)">+</button> </div> <div style="padding:.9rem;background:rgba(196,135,31,.05);border-radius:8px;border:1px solid rgba(196,135,31,.15)"> <div style="font-size:.6rem;letter-spacing:.14em;text-transform:uppercase;color:#C4871F;margin-bottom:.5rem;font-weight:600">Quick Categories</div> <div style="display:flex;flex-wrap:wrap;gap:.4rem"> ${['Praise ✦','Thanksgiving 🌿','Family 🏠','Church 🕊️','Healing ❤️','Missions 🌍','Personal 🙏','Salvation 🔥','Marriage ❤️','Finance 💛'].map(cat=>`<button onclick="setPrayerPrefix('${cat.split(' ')[0]}: ')" style="padding:.3rem .65rem;background:rgba(196,135,31,.1);border:1px solid rgba(196,135,31,.2);border-radius:20px;font-size:.68rem;color:#8B6914;cursor:pointer">${cat}</button>`).join(’’)}
</div>
</div>

  </section></div>`;
}

function renderJourney() {
const last28=Array.from({length:28},(_,i)=>{const d=new Date();d.setDate(d.getDate()-(27-i));return d.toISOString().split(‘T’)[0];});
return `<div class="fade"> <section style="margin:0 1.5rem 1.1rem;padding:1.2rem;background:rgba(255,255,255,.65);border-radius:14px;border:1px solid #EDE0CD"> <h2 style="font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:600;color:#1C1008;margin-bottom:.2rem">Your Faithfulness</h2> <p style="font-size:.67rem;letter-spacing:.06em;color:#A08060;margin-bottom:.9rem;font-style:italic">Last 28 days — every dot is a day walked with Him</p> <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:3px;margin-bottom:4px"> ${SHORT_DAYS.map(d=>`<div style="text-align:center;font-size:.52rem;letter-spacing:.08em;color:#A08060;padding-bottom:4px;text-transform:uppercase">${d}</div>`).join('')} </div> <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:6px;margin-bottom:.8rem"> ${last28.map(d=>`<div title="${d}" style="aspect-ratio:1;border-radius:50%;background:${S.completedDays.includes(d)?(d===TODAY?'#C4871F':'#5C7A51'):(d===TODAY?'#F0D4A0':'#EDE0CD')};border:${d===TODAY?'2px solid #C4871F':'none'};transform:${d===TODAY?'scale(1.2)':'scale(1)'};transition:all .3s ease"></div>`).join('')} </div> <div style="display:flex;gap:1.2rem;justify-content:center;font-size:.62rem;color:#A08060"> ${[['#5C7A51','Completed'],['#C4871F','Today'],['#EDE0CD','Not yet']].map(([bg,label])=>`<span style="display:flex;align-items:center;gap:5px"><span style="width:9px;height:9px;border-radius:50%;background:${bg};display:inline-block"></span>${label}</span>`).join('')} </div> </section> <section style="margin:0 1.5rem 1.1rem;padding:1.2rem;background:rgba(255,255,255,.65);border-radius:14px;border:1px solid #EDE0CD"> <h2 style="font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:600;color:#1C1008;margin-bottom:.9rem">Stats</h2> <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:.75rem;margin-bottom:.85rem"> ${[['Current Streak',`${S.streak} 🔥`,'#C4871F'],['This Month',S.completedDays.filter(d=>d.startsWith(TODAY.slice(0,7))).length,'#5C7A51'],['Total Days',S.completedDays.length,'#4568dc']].map(([label,val,color])=>`<div style="text-align:center;padding:.8rem .5rem;background:rgba(255,255,255,.65);border-radius:10px;border:1px solid #EDE0CD">
<div style="font-family:'Cormorant Garamond',serif;font-size:1.7rem;font-weight:600;color:${color};line-height:1">${val}</div>
<div style="font-size:.58rem;letter-spacing:.1em;text-transform:uppercase;color:#A08060;margin-top:.3rem;line-height:1.3">${label}</div>
</div>`).join('')} </div> ${S.streak>=7?`<div style="margin-bottom:.85rem;padding:.75rem;background:rgba(196,135,31,.07);border-radius:8px;border:1px solid rgba(196,135,31,.18);text-align:center">
<div style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:.9rem;color:#8B6914">${S.streak>=30?‘🏆 A month of faithful living — He is so pleased with you!’:S.streak>=14?‘⭐ Two weeks strong — keep walking!’:‘🌟 One week of faithfulness — beautiful!’}</div>
</div>`:''} <div> <div style="font-size:.6rem;letter-spacing:.12em;text-transform:uppercase;color:#A08060;margin-bottom:.5rem">Today's Category Breakdown</div> ${CATS.map(cat=>{const done=cat.habits.filter(h=>S.dayData.tasks[h.id]).length;const p=(done/cat.habits.length)*100;return`<div style="display:flex;align-items:center;gap:.5rem;margin-bottom:.4rem"><span style="font-size:.85rem;width:1.2rem">${cat.icon}</span><span style="font-size:.72rem;color:#1C1008;width:90px;font-weight:500">${cat.label}</span><div style="flex:1;height:5px;background:${cat.color}20;border-radius:3px;overflow:hidden"><div style="height:100%;width:${p}%;background:${cat.color};transition:width .5s ease"></div></div><span style="font-size:.68rem;color:${cat.color};font-weight:600;width:26px;text-align:right">${done}/${cat.habits.length}</span></div>`;}).join(’’)}
</div>
</section>

  </div>`;
}

function renderHistory() {
if(!S.histLoaded) { loadHistory(); return `<div class="fade"><section style="margin:0 1.5rem;padding:2rem;background:rgba(255,255,255,.65);border-radius:14px;border:1px solid #EDE0CD;text-align:center;color:#A08060;font-family:'Cormorant Garamond',serif;font-style:italic">Loading your history...</section></div>`; }
const getDOYD=ds=>{const d=new Date(ds+‘T12:00:00’),s=new Date(d.getFullYear(),0,0);return Math.floor((d-s)/86400000);};
return `<div class="fade"><section style="margin:0 1.5rem 1.1rem;padding:1.2rem;background:rgba(255,255,255,.65);border-radius:14px;border:1px solid #EDE0CD"> <h2 style="font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:600;color:#1C1008;margin-bottom:.2rem">Past Days</h2> <p style="font-size:.67rem;letter-spacing:.06em;color:#A08060;margin-bottom:.9rem;font-style:italic">A record of your walk with Him — tap any day to expand</p> ${S.histEntries.length===0?`<div style="text-align:center;padding:2rem 1rem"><div style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1.05rem;color:#A08060;margin-bottom:.5rem">No entries yet</div><div style="font-size:.75rem;color:#C4A882;line-height:1.6">As you check habits and write in your Journal, those days will be saved here.</div></div>`: S.histEntries.map((entry,i)=>{ const d=new Date(entry.date+'T12:00:00'); const label=`${FULL_DAYS[d.getDay()]}, ${MONTHS[d.getMonth()]} ${d.getDate()}, ${d.getFullYear()}`; const total=ALL_HABITS.filter(h=>entry.data.tasks&&entry.data.tasks[h.id]).length; const entryBg=getBG(getDOYD(entry.date)); const exp=S.expandedHist===i; return `<div style="margin-bottom:.55rem;border-radius:10px;border:1px solid #EDE0CD;overflow:hidden;background:rgba(255,255,255,.65)">
<div onclick="toggleHist(${i})" style="padding:.7rem 1rem;display:flex;align-items:center;gap:.65rem;cursor:pointer">
<div style="width:8px;height:8px;border-radius:50%;background:${entry.data.completed?'#5C7A51':'#C4A882'};flex-shrink:0"></div>
<div style="flex:1;min-width:0">
<div style="font-size:.78rem;font-weight:600;color:#1C1008">${label}</div>
<div style="font-size:.62rem;color:#A08060;margin-top:.1rem">${total}/${ALL_HABITS.length} habits${entry.scripture?’ · ‘+entry.scripture.ref:’’}</div>
</div>
<span style="color:#C4A882;font-size:.8rem;flex-shrink:0">${exp?‘▲’:‘▼’}</span>
</div>
${exp?`<div style="padding:0 1rem 1rem;border-top:1px solid #EDE0CD"> ${entry.scripture?`<div style="padding:.8rem;background:${entryBg};border-radius:8px;margin:.7rem 0"><div style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:.95rem;color:rgba(255,255,255,.92);line-height:1.55;margin-bottom:.4rem">”${esc(entry.scripture.text)}”</div><div style="font-size:.6rem;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.65);font-weight:600">${entry.scripture.ref}</div></div>`:''} ${CATS.map(cat=>{const done=cat.habits.filter(h=>entry.data.tasks&&entry.data.tasks[h.id]);if(!done.length)return'';return`<div style="margin-bottom:.65rem"><div style="font-size:.6rem;letter-spacing:.12em;text-transform:uppercase;color:${cat.color};font-weight:600;margin-bottom:.3rem">${cat.icon} ${cat.label}</div>${done.map(h=>`<div style="font-size:.78rem;color:#5C7A51;margin-bottom:.15rem">✓ ${h.label}</div>`).join(’’)}</div>`;}).join('')} ${(entry.data.water||0)>0?`<div style="font-size:.78rem;color:#1A4A6B;margin-bottom:.65rem">💧 Water: ${entry.data.water}/8 glasses</div>`:''} ${entry.data.gratitude&&entry.data.gratitude.some(g=>g)?`<div style="margin-bottom:.65rem"><div style="font-size:.58rem;letter-spacing:.14em;text-transform:uppercase;color:#C4871F;font-weight:600;margin-bottom:.3rem">Thanksgivings</div>${entry.data.gratitude.filter(g=>g).map((g,j)=>`<div style="font-size:.8rem;color:#1C1008;margin-bottom:.22rem;line-height:1.4">${j+1}. ${esc(g)}</div>`).join(’’)}</div>`:''} ${entry.data.notes?`<div><div style="font-size:.58rem;letter-spacing:.14em;text-transform:uppercase;color:#C4871F;font-weight:600;margin-bottom:.3rem">Revelations & Notes</div><div style="font-size:.82rem;color:#1C1008;line-height:1.65;white-space:pre-wrap">${esc(entry.data.notes)}</div></div>`:''} </div>`:’’}
</div>`;
}).join(’’)}

  </section></div>`;
}

// ── INPUT LISTENERS ──────────────────────────────────────────────────
function attachInputListeners() {
document.querySelectorAll(’[data-journal]’).forEach(el=>{
el.addEventListener(‘input’,function(){
const key=this.dataset.journal;
if(key.startsWith(‘grat-’)) { S.dayData.gratitude[parseInt(key.split(’-’)[1])]=this.value; saveDay(); }
else if(key===‘meditation’) { S.dayData.meditation=this.value; saveDay(); }
else if(key===‘notes’) { S.dayData.notes=this.value; saveDay(); }
else if(key===‘memverse’) { S.memVerse=this.value; lsSet(K(‘dev:memverse’),this.value); }
});
});
}

// ── ACTIONS ──────────────────────────────────────────────────────────
function setTab(tab) { S.tab=tab; if(tab===‘history’&&!S.histLoaded){loadHistory();}  render(); }
function toggleCat(id) { S.openCats[id]=!S.openCats[id]; render(); }
function toggleHabit(id) { S.dayData.tasks[id]=!S.dayData.tasks[id]; saveDay(); render(); }
function setWater(n) { S.dayData.water=n; saveDay(); render(); }
function togglePrayer(i) { S.dayData.prayers[i]={…S.dayData.prayers[i],done:!S.dayData.prayers[i].done}; saveDay(); render(); }
function deletePrayer(i) { S.dayData.prayers.splice(i,1); saveDay(); render(); }
function addPrayer() { const t=S.newPrayer.trim(); if(!t)return; S.dayData.prayers.push({text:t,done:false}); S.newPrayer=’’; saveDay(); render(); }
function setPrayerPrefix(prefix) { S.newPrayer=prefix; render(); const inp=document.getElementById(‘prayer-input’); if(inp){inp.focus();inp.setSelectionRange(inp.value.length,inp.value.length);} }
function toggleHist(i) { S.expandedHist=S.expandedHist===i?null:i; render(); }
function completeDay() {
if(S.done)return;
const yest=new Date(); yest.setDate(yest.getDate()-1); const y=yest.toISOString().split(‘T’)[0];
const ex=lsGet(K(‘dev:streak’)); let nc=1;
if(ex){if(ex.last===y)nc=ex.count+1;else if(ex.last===TODAY)nc=ex.count;}
lsSet(K(‘dev:streak’),{count:nc,last:TODAY});
const ncd=[…new Set([…S.completedDays,TODAY])].slice(-365);
S.completedDays=ncd; lsSet(K(‘dev:completed’),ncd);
S.dayData.completed=true; saveDay(); S.streak=nc; S.done=true; render();
}

// ── START ────────────────────────────────────────────────────────────
init();

// Start
try { init(); } catch(e) { showError(e.message + “ | “ + e.stack); }
</script>

</body>
</html>