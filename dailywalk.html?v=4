function saveDay() { lsSet(K(`dev:day:${TODAY}`), S.dayData); }
function esc(s) { return String(s||’’).replace(/&/g,’&’).replace(/</g,’<’).replace(/>/g,’>’).replace(/”/g,’"’); }

// ── INIT ─────────────────────────────────────────────────────────────
function loadProfile(name) {
S.profile = name;
