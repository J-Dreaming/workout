else { var fb=FB_S[(DOY-1+FB_S.length)%FB_S.length]; var fq=FB_Q[DOY%FB_Q.length]; S.content=Object.assign({},fb,{quote:fq.q,author:fq.a}); lsSet(‘dev:content:’ + DOY, S.content); }
